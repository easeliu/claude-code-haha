#!/usr/bin/env bash
# Wrapper script for PowerShell compatibility
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="$ROOT_DIR/.env"

if [[ "${CLAUDE_CODE_FORCE_RECOVERY_CLI:-0}" == "1" ]]; then
  exec bun --env-file="$ENV_FILE" "$ROOT_DIR/src/localRecoveryCli.ts" "$@"
fi

exec bun --env-file="$ENV_FILE" "$ROOT_DIR/src/entrypoints/cli.tsx" "$@"
